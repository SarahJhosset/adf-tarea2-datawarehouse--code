						"          intervalo_minimo_dias = toInteger(intervalo_minimo_dias),",
						"          dosis_ml = toDecimal(dosis_ml)) ~> derivedColumn2",
						"derivedColumn2 derive(intervalo_minimo_dias = iif(\r",
						"    isNull(intervalo_minimo_dias) \r",
						"    || trim(toString(intervalo_minimo_dias)) == '',\r",
						"    0,\r",
						"    toInteger(floor(toDecimal(toString(intervalo_minimo_dias))))\r",
						"),",
						"          condicion_especial = iif(\r",
						"    isNull(trim(condicion_especial)) || trim(condicion_especial) == '',\r",
						"    'No Aplica',\r",
						"    trim(condicion_especial)\r",
						")) ~> derivedColumn3",
						"derivedColumn3 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          vacuna_id as string,",
						"          vacuna_nombre as string,",
						"          enfermedad_previene as string,",
						"          grupo_pai as string,",
						"          numero_dosis as integer,",
						"          dosis_descripcion as string,",
						"          edad_aplicacion_descripcion as string,",
						"          edad_minima_dias as integer,",
						"          edad_maxima_dias as integer,",
						"          intervalo_minimo_dias as integer,",
						"          via_administracion as string,",
						"          sitio_aplicacion as string,",
						"          dosis_ml as decimal(4,2),",
						"          condicion_especial as string",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     mapColumn(",
