						"source(output(",
						"          fecha_key as integer,",
						"          fecha as date,",
						"          dia_semana as integer,",
						"          nombre_dia as string,",
						"          dia_mes as integer,",
						"          mes as integer,",
						"          nombre_mes as string,",
						"          trimestre as integer,",
						"          anio as integer,",
						"          es_fin_semana as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     query: 'SELECT \\n    CAST(CONVERT(VARCHAR(8), CAST(s.fecha_vacunacion AS DATE), 112) AS INT) AS fecha_key,\\n    CAST(s.fecha_vacunacion AS DATE) AS fecha,\\n    DATEPART(WEEKDAY, s.fecha_vacunacion) AS dia_semana,\\n    DATENAME(WEEKDAY, s.fecha_vacunacion) AS nombre_dia,\\n    DAY(s.fecha_vacunacion) AS dia_mes,\\n    MONTH(s.fecha_vacunacion) AS mes,\\n    DATENAME(MONTH, s.fecha_vacunacion) AS nombre_mes,\\n    DATEPART(QUARTER, s.fecha_vacunacion) AS trimestre,\\n    YEAR(s.fecha_vacunacion) AS anio,\\n    CASE \\n        WHEN DATEPART(WEEKDAY, s.fecha_vacunacion) IN (6, 7) THEN 1 \\n        ELSE 0 \\n    END AS es_fin_semana\\nFROM (\\n    SELECT DISTINCT CAST(fecha_vacunacion AS DATE) AS fecha_vacunacion\\n    FROM silver.vacunacion_consolidada\\n    WHERE fecha_vacunacion IS NOT NULL\\n) s',",
