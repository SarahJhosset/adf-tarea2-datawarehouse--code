						"source1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          vacuna_key as integer,",
						"          vacuna_id as string,",
						"          vacuna_nombre as string,",
						"          enfermedad_previene as string,",
						"          grupo_pai as string,",
						"          via_administracion as string",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     mapColumn(",
						"          fecha_key,",
						"          fecha,",
						"          dia_semana,",
						"          nombre_dia,",
						"          dia_mes,",
						"          mes,",
						"          nombre_mes,",
						"          trimestre,",
						"          anio,",
						"          es_fin_semana",
						"     )) ~> sink1"
					]
				}
			},
