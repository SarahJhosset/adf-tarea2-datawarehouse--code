								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "select1",
							"description": "Se está cambiando el nombre de source1 a select1 con las columnas \"registro_id, paciente_id, documento_identidad, nombres, apellido_paterno, apellido_materno, sexo, fecha_nacimiento, municipio_nombre, pueblo_indigena, fecha_vacunacion, vacuna_id, vacuna_nombre, numero_dosis, establecimiento_id, establecimiento_nombre, departamento, lote_vacuna, temperatura_conservacion, edad_dias_aplicacion, via_administracion\"."
						},
