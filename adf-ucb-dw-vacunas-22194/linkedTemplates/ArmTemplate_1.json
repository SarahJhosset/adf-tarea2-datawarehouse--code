						},
						{
							"name": "select5"
						},
						{
							"name": "filter1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          id_registro as string,",
						"          cod_paciente as string,",
						"          documento_identidad as string,",
						"          nombres as string,",
						"          primer_apellido as string,",
						"          segundo_apellido as string,",
						"          genero as string,",
						"          fec_nacimiento as string,",
						"          municipio as string,",
						"          pueblo_indigena as string,",
						"          fec_vacunacion as string,",
						"          cod_vacuna as string,",
						"          desc_vacuna as string,",
						"          nro_dosis as string,",
						"          cod_establecimiento as string,",
						"          desc_establecimiento as string,",
						"          depto as string,",
						"          nro_lote as string,",
						"          temp_conservacion as string,",
						"          edad_dias as string,",
						"          via_aplicacion as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source(output(",
						"          registro_id as string,",
						"          paciente_id as string,",
						"          ci_paciente as string,",
						"          nombre_paciente as string,",
						"          apellido_paterno as string,",
						"          apellido_materno as string,",
						"          sexo as string,",
						"          fecha_nacimiento as string,",
						"          municipio_residencia as string,",
						"          comunidad_indigena as string,",
						"          fecha_vacunacion as string,",
						"          vacuna_id as string,",
						"          vacuna_nombre as string,",
						"          numero_dosis as string,",
						"          establecimiento_id as string,",
						"          nombre_establecimiento as string,",
						"          departamento as string,",
						"          lote_vacuna as string,",
						"          temperatura_conservacion as string,",
						"          edad_dias_aplicacion as string,",
						"          aplicacion_oportuna as string,",
						"          via_administracion as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source2",
						"source(output(",
						"          record_id as string,",
						"          sync_timestamp as string,",
						"          device_id as string,",
						"          patient_id as string,",
						"          patient_ci as string,",
						"          patient_name as string,",
						"          patient_last_name_1 as string,",
						"          patient_last_name_2 as string,",
						"          patient_sex as string,",
						"          patient_birth_date as string,",
						"          patient_department as string,",
						"          patient_municipality as string,",
						"          patient_community as string,",
						"          patient_indigenous as string,",
						"          vaccination_date as string,",
						"          vaccine_code as string,",
						"          vaccine_name as string,",
						"          dose_number as string,",
						"          facility_code as string,",
						"          facility_name as string,",
						"          lot_number as string,",
						"          storage_temp_celsius as string,",
						"          patient_age_days as string,",
						"          administration_route as string,",
						"          gps_latitude as string,",
						"          gps_longitude as string,",
						"          gps_accuracy_meters as string,",
						"          observations as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source3",
						"source(output(",
						"          establecimiento_id as string,",
						"          nombre_establecimiento as string,",
						"          tipo_establecimiento as string,",
						"          nivel_atencion as integer,",
						"          zona as string,",
						"          sedes as string,",
						"          red_salud as string,",
						"          departamento as string,",
						"          municipio as string,",
						"          latitud as decimal(12,8),",
						"          longitud as decimal(12,8),",
						"          tiene_cadena_frio as boolean,",
						"          activo as boolean",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     format: 'table') ~> source4",
						"source(output(",
						"          municipio_id as string,",
						"          municipio_nombre as string,",
						"          departamento as string,",
						"          codigo_departamento as string,",
						"          zona_geografica as string,",
						"          es_capital_departamental as boolean,",
						"          poblacion_depto_estimada as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     format: 'table') ~> source5",
						"source1 select(mapColumn(",
						"          registro_id = id_registro,",
						"          paciente_id = cod_paciente,",
						"          documento_identidad,",
						"          nombres,",
						"          apellido_paterno = primer_apellido,",
						"          apellido_materno = segundo_apellido,",
						"          sexo = genero,",
						"          fecha_nacimiento = fec_nacimiento,",
						"          municipio_nombre = municipio,",
						"          pueblo_indigena,",
						"          fecha_vacunacion = fec_vacunacion,",
						"          vacuna_id = cod_vacuna,",
						"          vacuna_nombre = desc_vacuna,",
						"          numero_dosis = nro_dosis,",
						"          establecimiento_id = cod_establecimiento,",
						"          establecimiento_nombre = desc_establecimiento,",
						"          departamento = depto,",
						"          lote_vacuna = nro_lote,",
						"          temperatura_conservacion = temp_conservacion,",
						"          edad_dias_aplicacion = edad_dias,",
						"          via_administracion = via_aplicacion",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select1",
						"source2 select(mapColumn(",
						"          registro_id,",
						"          paciente_id,",
						"          documento_identidad = ci_paciente,",
						"          nombres = nombre_paciente,",
						"          apellido_paterno,",
						"          apellido_materno,",
						"          sexo,",
						"          fecha_nacimiento,",
						"          municipio_nombre = municipio_residencia,",
						"          pueblo_indigena = comunidad_indigena,",
						"          fecha_vacunacion,",
						"          vacuna_id,",
						"          vacuna_nombre,",
						"          numero_dosis,",
						"          establecimiento_id,",
						"          establecimiento_nombre = nombre_establecimiento,",
						"          departamento,",
						"          lote_vacuna,",
						"          temperatura_conservacion,",
						"          edad_dias_aplicacion,",
						"          aplicacion_oportuna,",
						"          via_administracion",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select2",
						"source3 select(mapColumn(",
						"          registro_id = record_id,",
						"          paciente_id = patient_id,",
						"          documento_identidad = patient_ci,",
						"          nombres = patient_name,",
						"          apellido_paterno = patient_last_name_1,",
						"          apellido_materno = patient_last_name_2,",
						"          sexo = patient_sex,",
						"          fecha_nacimiento = patient_birth_date,",
						"          departamento = patient_department,",
						"          municipio_nombre = patient_municipality,",
						"          pueblo_indigena = patient_indigenous,",
						"          fecha_vacunacion = vaccination_date,",
						"          vacuna_id = vaccine_code,",
						"          vacuna_nombre = vaccine_name,",
						"          numero_dosis = dose_number,",
						"          establecimiento_id = facility_code,",
						"          establecimiento_nombre = facility_name,",
						"          lote_vacuna = lot_number,",
						"          temperatura_conservacion = storage_temp_celsius,",
						"          edad_dias_aplicacion = patient_age_days,",
						"          via_administracion = administration_route,",
						"          latitud = gps_latitude,",
						"          longitud = gps_longitude,",
						"          observaciones = observations",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select3",
						"select1 derive(pueblo_indigena = iif(upper(trim(pueblo_indigena)) == 'SÍ', true(), false()),",
						"          sexo = iif(     upper(trim(sexo)) == 'MASCULINO',     'M',     'F' ),",
						"          fecha_nacimiento = toDate(fecha_nacimiento, 'dd/MM/yyyy'),",
						"          fecha_vacunacion = toTimestamp(fecha_vacunacion, 'dd/MM/yyyy'),",
						"          documento_identidad = replace(documento_identidad, ' LP', ''),",
						"          departamento = upper(trim(departamento)),",
						"          numero_dosis = toInteger(numero_dosis),",
						"          edad_dias_aplicacion = toInteger(edad_dias_aplicacion),",
						"          temperatura_conservacion = toDecimal(temperatura_conservacion),",
						"          origen_datos = 'LA PAZ') ~> derivedColumn1",
						"select2 derive(pueblo_indigena = iif(upper(trim(pueblo_indigena)) == 'true', true(), false()),",
						"          fecha_nacimiento = toDate(fecha_nacimiento,'d/M/yyyy'),",
						"          fecha_vacunacion = toTimestamp(fecha_vacunacion,'d/M/yyyy'),",
						"          numero_dosis = toInteger(numero_dosis),",
						"          departamento = trim(departamento),",
						"          temperatura_conservacion = toDecimal(temperatura_conservacion),",
						"          edad_dias_aplicacion = toInteger(edad_dias_aplicacion),",
						"          aplicacion_oportuna = toBoolean(aplicacion_oportuna),",
						"          documento_identidad = replace(documento_identidad, ' SC', '')) ~> derivedColumn2",
						"select3 derive(pueblo_indigena = iif(pueblo_indigena == 'True', true(), false()),",
						"          sexo = upper(trim(sexo)),",
						"          numero_dosis = toInteger(numero_dosis),",
						"          fecha_nacimiento = toDate(fecha_nacimiento, 'd/M/yyyy'),",
						"          fecha_vacunacion = toTimestamp(fecha_vacunacion, 'yyyy-MM-dd\\'T\\'HH:mm:ss'),",
						"          temperatura_conservacion = toDecimal(temperatura_conservacion),",
						"          edad_dias_aplicacion = toInteger(edad_dias_aplicacion),",
						"          documento_identidad = iif(     isNull(documento_identidad) || trim(documento_identidad) == '',     '00000000',     regexReplace(documento_identidad, '[^0-9]', '') ),",
						"          departamento = upper(trim(departamento))) ~> derivedColumn3",
						"derivedColumn2 derive(departamento = iif(\r",
						"    regexMatch(lower(trim(departamento)), '.*cruz.*'),\r",
						"    'SANTA CRUZ',\r",
						"    upper(trim(departamento))\r",
						"),",
						"          origen_datos = 'SANTA CRUZ') ~> derivedColumn4",
						"derivedColumn3 derive(aplicacion_oportuna = iif(\r",
						"    isNull(fecha_vacunacion),\r",
						"    false(),\r",
						"    iif(\r",
						"        fecha_vacunacion <= currentTimestamp(),\r",
						"        true(),\r",
						"        false()\r",
						"    )\r",
						"),",
						"          latitud = toDecimal(    concat(        substring(replace(latitud,'.',''),1,3),        '.',        substring(replace(latitud,'.',''),4)    ),12,6),",
						"          longitud = iif(    size(split(longitud, '\\\\.')) > 2,    toDecimal(        regexReplace(longitud, '\\\\.(?=[^.]*$)', ''),    12,6),    toDecimal(        concat(            substring(replace(longitud,'.',''),1,                length(replace(longitud,'.',''))-6            ),            '.',            right(replace(longitud,'.',''),6)        ),    12,6)),",
						"          origen_datos = 'RURAL MOVIL') ~> derivedColumn5",
						"derivedColumn1 derive(aplicacion_oportuna = iif(    isNull(fecha_vacunacion),    false(),    iif(        fecha_vacunacion <= currentTimestamp(),        true(),        false()    ))) ~> derivedColumn6",
						"derivedColumn6, derivedColumn4 union(byName: true)~> union1",
						"union1, derivedColumn5 union(byName: true)~> union2",
						"union2 derive(observaciones = iif(\r",
						"    isNull(observaciones),\r",
						"    'sin observaciones',\r",
						"    observaciones\r",
						")) ~> derivedColumn7",
						"derivedColumn7, source4 lookup(union2@establecimiento_id == source4@establecimiento_id,",
						"     multiple: false,",
						"     pickup: 'any',",
						"     broadcast: 'auto')~> lookup1",
						"lookup1 select(mapColumn(",
						"          registro_id,",
						"          paciente_id,",
						"          documento_identidad,",
						"          nombres,",
						"          apellido_paterno,",
						"          apellido_materno,",
						"          sexo,",
						"          fecha_nacimiento,",
						"          municipio_nombre,",
						"          pueblo_indigena,",
						"          fecha_vacunacion,",
						"          vacuna_id,",
						"          vacuna_nombre,",
						"          numero_dosis,",
						"          establecimiento_id = union2@establecimiento_id,",
						"          establecimiento_nombre,",
						"          departamento = union2@departamento,",
						"          lote_vacuna,",
						"          temperatura_conservacion,",
						"          edad_dias_aplicacion,",
						"          via_administracion,",
						"          origen_datos,",
						"          aplicacion_oportuna,",
						"          observaciones,",
						"          latitud = source4@latitud,",
						"          longitud = source4@longitud",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select4",
						"select4, source5 lookup(select4@municipio_nombre == source5@municipio_nombre,",
						"     multiple: false,",
						"     pickup: 'any',",
						"     broadcast: 'auto')~> lookup2",
						"lookup2 select(mapColumn(",
						"          registro_id,",
						"          paciente_id,",
						"          documento_identidad,",
						"          nombres,",
						"          apellido_paterno,",
						"          apellido_materno,",
						"          sexo,",
						"          fecha_nacimiento,",
						"          municipio_nombre = select4@municipio_nombre,",
						"          pueblo_indigena,",
						"          fecha_vacunacion,",
						"          vacuna_id,",
						"          vacuna_nombre,",
						"          numero_dosis,",
						"          establecimiento_id,",
						"          establecimiento_nombre,",
						"          departamento = select4@departamento,",
						"          lote_vacuna,",
						"          temperatura_conservacion,",
						"          edad_dias_aplicacion,",
						"          via_administracion,",
						"          origen_datos,",
						"          aplicacion_oportuna,",
						"          observaciones,",
						"          latitud,",
						"          longitud,",
						"          municipio_id",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select5",
						"select5 filter(!isNull(municipio_id)) ~> filter1",
						"filter1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          registro_id as string,",
						"          paciente_id as string,",
						"          documento_identidad as string,",
						"          nombres as string,",
						"          apellido_paterno as string,",
						"          apellido_materno as string,",
						"          sexo as string,",
						"          fecha_nacimiento as date,",
						"          municipio_nombre as string,",
						"          municipio_id as string,",
						"          pueblo_indigena as boolean,",
						"          fecha_vacunacion as timestamp,",
						"          vacuna_id as string,",
						"          vacuna_nombre as string,",
						"          numero_dosis as integer,",
						"          establecimiento_id as string,",
						"          establecimiento_nombre as string,",
						"          departamento as string,",
						"          lote_vacuna as string,",
						"          temperatura_conservacion as decimal(5,2),",
						"          edad_dias_aplicacion as integer,",
						"          via_administracion as string,",
						"          latitud as decimal(12,8),",
						"          longitud as decimal(12,8),",
						"          observaciones as string,",
						"          origen_datos as string,",
						"          aplicacion_oportuna as boolean,",
						"          fecha_carga as timestamp",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     mapColumn(",
						"          registro_id,",
						"          paciente_id,",
						"          documento_identidad,",
						"          nombres,",
						"          apellido_paterno,",
						"          apellido_materno,",
						"          sexo,",
						"          fecha_nacimiento,",
						"          municipio_nombre,",
						"          municipio_id,",
						"          pueblo_indigena,",
						"          fecha_vacunacion,",
						"          vacuna_id,",
						"          vacuna_nombre,",
						"          numero_dosis,",
						"          establecimiento_id,",
						"          establecimiento_nombre,",
						"          departamento,",
						"          lote_vacuna,",
						"          temperatura_conservacion,",
						"          edad_dias_aplicacion,",
						"          via_administracion,",
						"          latitud,",
						"          longitud,",
						"          observaciones,",
						"          origen_datos,",
						"          aplicacion_oportuna",
						"     )) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_gold_dim_establecimiento')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"folder": {
					"name": "gold"
				},
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "silver_vacunacion_consolidada",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "gold_dim_establecimiento",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [],
					"scriptLines": [
						"source(output(",
						"          establecimiento_id as string,",
						"          nombre_establecimiento as string,",
						"          departamento as string,",
						"          municipio as string",
						"     ),",
						"     allowSchemaDrift: true,",
