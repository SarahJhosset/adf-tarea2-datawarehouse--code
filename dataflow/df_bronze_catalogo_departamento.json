{
	"name": "df_bronze_catalogo_departamento",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_departamentos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_municipios",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as string,",
				"          poblacion_depto_estimada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(municipio_id = trim(municipio_id),",
				"          municipio_nombre = trim(municipio_nombre),",
				"          departamento = upper(trim(departamento)),",
				"          codigo_departamento = upper(trim(codigo_departamento)),",
				"          zona_geografica = trim(zona_geografica),",
				"          es_capital_departamental = trim(es_capital_departamental),",
				"          poblacion_depto_estimada = trim(poblacion_depto_estimada)) ~> derivedColumn1",
				"derivedColumn1 derive(poblacion_depto_estimada = toInteger(poblacion_depto_estimada),",
				"          es_capital_departamental = toBoolean(es_capital_departamental)) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          municipio_id as string,",
				"          municipio_nombre as string,",
				"          departamento as string,",
				"          codigo_departamento as string,",
				"          zona_geografica as string,",
				"          es_capital_departamental as boolean,",
				"          poblacion_depto_estimada as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          municipio_id,",
				"          municipio_nombre,",
				"          departamento,",
				"          codigo_departamento,",
				"          zona_geografica,",
				"          es_capital_departamental,",
				"          poblacion_depto_estimada",
				"     )) ~> sink1"
			]
		}
	}
}