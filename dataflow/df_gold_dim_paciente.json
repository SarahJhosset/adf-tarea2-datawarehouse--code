{
	"name": "df_gold_dim_paciente",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_paciente",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          paciente_id as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as date,",
				"          pueblo_indigena as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    paciente_id,\\n    documento_identidad,\\n    nombres,\\n    apellido_paterno,\\n    apellido_materno,\\n    sexo,\\n    fecha_nacimiento,\\n    pueblo_indigena\\nFROM silver.vacunacion_consolidada\\nWHERE paciente_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paciente_key as integer,",
				"          paciente_id as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as date,",
				"          pueblo_indigena as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paciente_id,",
				"          documento_identidad,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          pueblo_indigena",
				"     )) ~> sink1"
			]
		}
	}
}