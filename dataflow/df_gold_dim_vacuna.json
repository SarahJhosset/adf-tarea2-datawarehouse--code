{
	"name": "df_gold_dim_vacuna",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_vacuna",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    vacuna_id,\\n    vacuna_nombre,\\n    via_administracion\\nFROM silver.vacunacion_consolidada\\nWHERE vacuna_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacuna_key as integer,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          enfermedad_previene as string,",
				"          grupo_pai as string,",
				"          via_administracion as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          via_administracion",
				"     )) ~> sink1"
			]
		}
	}
}